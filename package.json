{
  "name": "campus-event-ecosystem",
  "version": "1.0.0",
  "description": "Full-stack Campus Event Management Platform with role-based access",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:smoke": "k6 run load-tests/k6-smoke-test.js",
    "test:load": "k6 run load-tests/k6-load-test.js",
    "test:load:json": "k6 run --out json=load-tests/results/results.json --summary-trend-stats min,avg,med,p(90),p(95),p(99),max load-tests/k6-load-test.js",
    "test:analyze": "node load-tests/analyze-results.js"
  },
  "keywords": [
    "events",
    "campus",
    "management",
    "mern"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "lru-cache": "^11.5.1",
    "method-override": "^3.0.0",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.38.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
