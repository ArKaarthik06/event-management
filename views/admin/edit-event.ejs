<div class="container-sm" style="padding-top:2rem;max-width:700px;">
  <div class="page-header">
    <h1>✏️ Edit Event</h1>
    <a href="/admin/dashboard" class="btn btn-secondary">← Dashboard</a>
  </div>

  <div class="form-card">
    <form action="/admin/events/<%= event._id %>?_method=PUT" method="POST" enctype="multipart/form-data" id="edit-event-form">
      <div class="form-group">
        <label for="title">Event Title</label>
        <input type="text" id="title" name="title" value="<%= event.title %>" maxlength="100" required>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" maxlength="2000" required><%= event.description %></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="category">Category</label>
          <select id="category" name="category" required>
            <option value="workshop" <%= event.category === 'workshop' ? 'selected' : '' %>>🔧 Workshop</option>
            <option value="hackathon" <%= event.category === 'hackathon' ? 'selected' : '' %>>💻 Hackathon</option>
            <option value="seminar" <%= event.category === 'seminar' ? 'selected' : '' %>>🎓 Seminar</option>
            <option value="competition" <%= event.category === 'competition' ? 'selected' : '' %>>🏆 Competition</option>
            <option value="cultural" <%= event.category === 'cultural' ? 'selected' : '' %>>🎭 Cultural</option>
            <option value="sports" <%= event.category === 'sports' ? 'selected' : '' %>>⚽ Sports</option>
            <option value="club" <%= event.category === 'club' ? 'selected' : '' %>>🎪 Club Activity</option>
            <option value="other" <%= event.category === 'other' ? 'selected' : '' %>>📌 Other</option>
          </select>
        </div>
        <div class="form-group">
          <label for="venue">Venue</label>
          <input type="text" id="venue" name="venue" value="<%= event.venue %>" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="date">Date</label>
          <input type="date" id="date" name="date" value="<%= formatDateInput(event.date) %>" required>
        </div>
        <div class="form-group">
          <label for="time">Time</label>
          <input type="text" id="time" name="time" value="<%= event.time %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="fee">Fee (₹)</label>
          <input type="number" id="fee" name="fee" min="0" value="<%= event.fee %>">
        </div>
        <div class="form-group">
          <label for="capacity">Capacity</label>
          <input type="number" id="capacity" name="capacity" min="1" value="<%= event.capacity %>" required>
        </div>
      </div>
      <div class="form-group">
        <label>Current Image</label>
        <img src="<%= event.image %>" alt="Current" style="max-height:150px;border-radius:8px;margin-bottom:8px;display:block;" onerror="this.style.display='none'">
        <label for="image">Replace Image (optional)</label>
        <input type="file" id="image" name="image" accept="image/*">
        <img class="image-preview" style="display:none;margin-top:12px;max-height:200px;border-radius:8px;" alt="Preview">
      </div>
      <div class="form-footer">
        <button type="submit" class="btn btn-primary btn-lg">Update Event</button>
        <a href="/admin/dashboard">Cancel</a>
      </div>
    </form>
  </div>
</div>
