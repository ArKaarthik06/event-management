<div class="container-sm" style="padding-top:2rem;max-width:700px;">
  <div class="page-header">
    <h1>✨ Create New Event</h1>
    <a href="/admin/dashboard" class="btn btn-secondary">← Dashboard</a>
  </div>

  <div class="form-card">
    <form action="/admin/events" method="POST" enctype="multipart/form-data" id="create-event-form">
      <div class="form-group">
        <label for="title">Event Title</label>
        <input type="text" id="title" name="title" placeholder="e.g. AI Workshop 2026" maxlength="100" required>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" placeholder="Describe your event in detail..." maxlength="2000" required></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="category">Category</label>
          <select id="category" name="category" required>
            <option value="workshop">🔧 Workshop</option>
            <option value="hackathon">💻 Hackathon</option>
            <option value="seminar">🎓 Seminar</option>
            <option value="competition">🏆 Competition</option>
            <option value="cultural">🎭 Cultural</option>
            <option value="sports">⚽ Sports</option>
            <option value="club">🎪 Club Activity</option>
            <option value="other">📌 Other</option>
          </select>
        </div>
        <div class="form-group">
          <label for="venue">Venue</label>
          <input type="text" id="venue" name="venue" placeholder="e.g. Auditorium A" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="date">Date</label>
          <input type="date" id="date" name="date" required>
        </div>
        <div class="form-group">
          <label for="time">Time</label>
          <input type="text" id="time" name="time" placeholder="e.g. 10:00 AM" value="10:00 AM">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="fee">Fee (₹)</label>
          <input type="number" id="fee" name="fee" min="0" value="0" placeholder="0 for free">
        </div>
        <div class="form-group">
          <label for="capacity">Capacity</label>
          <input type="number" id="capacity" name="capacity" min="1" placeholder="Max attendees" required>
        </div>
      </div>
      <div class="form-group">
        <label for="image">Event Image (optional)</label>
        <input type="file" id="image" name="image" accept="image/*">
        <img class="image-preview" style="display:none;margin-top:12px;max-height:200px;border-radius:8px;" alt="Preview">
      </div>
      <div class="form-footer">
        <button type="submit" class="btn btn-primary btn-lg">Create Event</button>
        <a href="/admin/dashboard">Cancel</a>
      </div>
    </form>
  </div>
</div>
