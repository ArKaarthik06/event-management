<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Campus Event Management Platform — Discover, register, and manage campus events">
  <title><%= typeof title !== 'undefined' ? title + ' | Campus Events' : 'Campus Events' %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/" class="navbar-logo"><span>🎓</span> CampusEvents</a>
      <button class="hamburger" aria-label="Toggle menu">☰</button>
      <ul class="navbar-links">
        <li><a href="/" id="nav-home">Browse Events</a></li>
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <li><a href="/my-events" id="nav-myevents">My Events</a></li>
          <% if (currentUser.role === 'admin' || currentUser.role === 'root_admin') { %>
            <li><a href="/admin/dashboard" id="nav-admin" class="btn-nav">Admin Dashboard</a></li>
          <% } %>
          <li><a href="/auth/logout" id="nav-logout">Logout</a></li>
        <% } else { %>
          <li><a href="/auth/login" id="nav-login">Login</a></li>
          <li><a href="/auth/signup" id="nav-signup" class="btn-nav">Sign Up</a></li>
        <% } %>
      </ul>
    </div>
  </nav>

  <!-- Flash Messages -->
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="flash-container">
      <% success.forEach(msg => { %>
        <div class="flash flash-success">✅ <%= msg %><button class="close-btn">&times;</button></div>
      <% }); %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="flash-container">
      <% error.forEach(msg => { %>
        <div class="flash flash-error">❌ <%= msg %><button class="close-btn">&times;</button></div>
      <% }); %>
    </div>
  <% } %>

  <!-- Page Content -->
  <%- body %>

  <!-- Footer -->
  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> CampusEvents — Built for campus communities</p>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
